# ============================================================
# NetVisionConnect — image kiosque Raspberry Pi 4 / 5 (64-bit)
# Base : Raspberry Pi OS Lite (arm64) · Construite avec pimod
#
# Note : pimod exécute les RUN SANS shell (argv direct), et n'installe
# pas les dossiers dont le parent manque. On garde donc des RUN simples,
# on stocke les fichiers dans /opt/netvision, et setup.sh (vrai shell)
# fait toute la configuration après l'installation des paquets.
# ============================================================
FROM raspios-lite.img

PUMP 1800M

# Répertoires de préparation
RUN mkdir -p /opt/netvision/home /opt/netvision/defaults

# --- Scripts NetVisionConnect ---
INSTALL files/usr/local/bin/netvision-kiosk.sh /usr/local/bin/netvision-kiosk.sh
INSTALL files/usr/local/bin/netvision-readonly /usr/local/bin/netvision-readonly
INSTALL files/usr/local/bin/netvision-firstboot.sh /usr/local/bin/netvision-firstboot.sh

# --- Services / cron ---
INSTALL files/etc/systemd/system/netvision-firstboot.service /etc/systemd/system/netvision-firstboot.service
INSTALL files/etc/cron.d/netvision-reboot /etc/cron.d/netvision-reboot
# watchdog.conf : posé par setup.sh APRÈS le paquet (évite la question dpkg)
INSTALL files/etc/watchdog.conf /opt/netvision/watchdog.conf

# --- Fichiers consommés par setup.sh (zone de préparation) ---
INSTALL files/usr/share/plymouth/themes/netvision /opt/netvision/theme
INSTALL files/home/kiosk/.bash_profile /opt/netvision/home/.bash_profile
INSTALL files/home/kiosk/.xinitrc /opt/netvision/home/.xinitrc
INSTALL files/etc/systemd/system/getty@tty1.service.d/autologin.conf /opt/netvision/autologin.conf
INSTALL files/boot/netvision/url.txt /opt/netvision/defaults/url.txt
INSTALL files/boot/netvision/orientation.txt /opt/netvision/defaults/orientation.txt
INSTALL setup.sh /opt/netvision/setup.sh

# --- Permissions ---
RUN chmod +x /usr/local/bin/netvision-kiosk.sh /usr/local/bin/netvision-readonly /usr/local/bin/netvision-firstboot.sh /opt/netvision/setup.sh

# --- Toute la configuration (vrai shell, après installation des paquets) ---
RUN bash /opt/netvision/setup.sh
